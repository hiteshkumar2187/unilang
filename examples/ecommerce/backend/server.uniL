// ─── Helpers ──────────────────────────────────────────────────

def load_products_from_db() {
    rows = db_query("SELECT * FROM products ORDER BY is_trending DESC, rating DESC", []);
    products = [];
    j = 0;
    while j < len(rows) {
        r = rows[j];
        j = j + 1;
        p = {
            "id":          r["id"],
            "name":        r["name"],
            "brand":       r["brand"],
            "category":    r["category"],
            "subcategory": r["subcategory"],
            "price":       r["price"],
            "originalPrice": r["original_price"],
            "discount":    r["discount"],
            "imageUrl":    r["image_url"],
            "description": r["description"],
            "stock":       r["stock"],
            "rating":      r["rating"],
            "reviewCount": r["review_count"],
            "isTrending":  r["is_trending"] == 1,
            "isNew":       r["is_new"] == 1,
            "gender":      r["gender"],
            "sizes":       split(r["sizes"], ","),
            "colors":      split(r["colors"], ","),
            "tags":        split(r["tags"], ","),
            "available":   r["stock"] > 0
        };
        products.append(p);
    }
    return products;
}

def gen_order_id() {
    order_counter = order_counter + 1;
    return "ORD-" + str(order_counter);
}

def json_ok(data) {
    return {"status": 200, "body": to_json(data), "content_type": "application/json"};
}

def json_err(code, msg) {
    return {"status": code, "body": to_json({"error": msg}), "content_type": "application/json"};
}

def parse_int_param(input_val, def_val) {
    if input_val == "" { return def_val; }
    if input_val == null { return def_val; }
    return int(input_val);
}

def get_query_param(query, key) {
    if query == "" { return ""; }
    if query == null { return ""; }
    parts = split(query, "&");
    i = 0;
    while i < len(parts) {
        kv = split(parts[i], "=");
        i = i + 1;
        if len(kv) >= 2 {
            if kv[0] == key { return kv[1]; }
        }
    }
    return "";
}

// ─── API Handlers ─────────────────────────────────────────────

def handle_health(req) {
    products = load_products_from_db();
    categories = [];
    seen_cats = {};
    i = 0;
    while i < len(products) {
        cat = products[i]["category"];
        i = i + 1;
        if seen_cats[cat] != true {
            seen_cats[cat] = true;
            categories.append(cat);
        }
    }
    return json_ok({
        "status": "healthy",
        "service": "SHYNX Fashion E-Commerce",
        "version": "1.0.0",
        "products": len(products),
        "categories": len(categories),
        "uptime": "running"
    });
}

def sort_products(items, field, desc) {
    n = len(items);
    i = 0;
    while i < n {
        j = 0;
        while j < n - i - 1 {
            a = items[j][field];
            b = items[j+1][field];
            swap = false;
            if desc == true  { if a < b { swap = true; } }
            if desc == false { if a > b { swap = true; } }
            if swap {
                tmp = items[j];
                items[j] = items[j+1];
                items[j+1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return items;
}

def sort_newest(items) {
    n = len(items);
    i = 0;
    while i < n {
        j = 0;
        while j < n - i - 1 {
            a_new = 0;
            b_new = 0;
            if items[j]["isNew"] == true   { a_new = 1; }
            if items[j+1]["isNew"] == true { b_new = 1; }
            if a_new < b_new {
                tmp = items[j];
                items[j] = items[j+1];
                items[j+1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return items;
}

def handle_get_products(req) {
    query = req["query"];
    page      = parse_int_param(get_query_param(query, "page"), 1);
    page_size = parse_int_param(get_query_param(query, "pageSize"), 24);
    category  = get_query_param(query, "category");
    gender    = get_query_param(query, "gender");
    search    = get_query_param(query, "search");
    min_price = get_query_param(query, "minPrice");
    max_price = get_query_param(query, "maxPrice");
    sort_by   = get_query_param(query, "sort");
    trending  = get_query_param(query, "trending");
    is_new    = get_query_param(query, "new");

    all_products = load_products_from_db();

    // Python-style filtering
    filtered = [];
    i = 0;
    while i < len(all_products) {
        p = all_products[i];
        i = i + 1;
        ok = true;
        if category != "" {
            if p["category"] != category { ok = false; }
        }
        if gender != "" {
            if p["gender"] != gender {
                if p["gender"] != "unisex" { ok = false; }
            }
        }
        if search != "" {
            name_lower  = lower(p["name"]);
            brand_lower = lower(p["brand"]);
            srch_lower  = lower(search);
            found = false;
            if contains(name_lower, srch_lower)  { found = true; }
            if contains(brand_lower, srch_lower) { found = true; }
            if found == false { ok = false; }
        }
        if min_price != "" {
            mp = float(min_price);
            if p["price"] < mp { ok = false; }
        }
        if max_price != "" {
            mx = float(max_price);
            if p["price"] > mx { ok = false; }
        }
        if trending == "true" {
            if p["isTrending"] != true { ok = false; }
        }
        if is_new == "true" {
            if p["isNew"] != true { ok = false; }
        }
        if ok { filtered.append(p); }
    }

    // Sorting
    if sort_by == "price_asc" {
        filtered = sort_products(filtered, "price", false);
    }
    if sort_by == "price_desc" {
        filtered = sort_products(filtered, "price", true);
    }
    if sort_by == "rating" {
        filtered = sort_products(filtered, "rating", true);
    }
    if sort_by == "newest" {
        filtered = sort_newest(filtered);
    }

    total = len(filtered);
    start = (page - 1) * page_size;
    end   = start + page_size;
    if end > total { end = total; }
    page_items = [];
    k = start;
    while k < end {
        page_items.append(filtered[k]);
        k = k + 1;
    }

    return json_ok({
        "products":   page_items,
        "total":      total,
        "page":       page,
        "pageSize":   page_size,
        "totalPages": ceil(total / page_size)
    });
}

def handle_get_product(req, product_id) {
    // Try Redis cache first (Java-style: check resource, Python-style: dict access)
    cached = redis_get("product:" + product_id);
    if cached != null {
        return {"status": 200, "body": cached, "content_type": "application/json"};
    }

    rows = db_query("SELECT * FROM products WHERE id = ?", [product_id]);
    if len(rows) == 0 {
        return json_err(404, "Product not found");
    }
    r = rows[0];
    product = {
        "id":          r["id"],
        "name":        r["name"],
        "brand":       r["brand"],
        "category":    r["category"],
        "subcategory": r["subcategory"],
        "price":       r["price"],
        "originalPrice": r["original_price"],
        "discount":    r["discount"],
        "imageUrl":    r["image_url"],
        "description": r["description"],
        "stock":       r["stock"],
        "rating":      r["rating"],
        "reviewCount": r["review_count"],
        "isTrending":  r["is_trending"] == 1,
        "isNew":       r["is_new"] == 1,
        "gender":      r["gender"],
        "sizes":       split(r["sizes"], ","),
        "colors":      split(r["colors"], ","),
        "tags":        split(r["tags"], ","),
        "available":   r["stock"] > 0
    };

    // Get reviews
    reviews = db_query("SELECT * FROM reviews WHERE product_id = ? ORDER BY created_at DESC LIMIT 10", [product_id]);

    // Recommendations (PDP)
    all_products = load_products_from_db();
    similar = rec_recommend_pdp(all_products, product, 6);

    resp_body = to_json({
        "product":         product,
        "reviews":         reviews,
        "recommendations": similar
    });

    // Cache for 5 min
    redis_setex("product:" + product_id, 300, resp_body);

    return {"status": 200, "body": resp_body, "content_type": "application/json"};
}

def handle_get_categories(req) {
    all_products = load_products_from_db();
    cats = {};
    i = 0;
    while i < len(all_products) {
        p = all_products[i];
        i = i + 1;
        cat = p["category"];
        if cats[cat] == null { cats[cat] = 0; }
        cats[cat] = cats[cat] + 1;
    }
    result = [];
    all_cats = ["Dresses","Tops","Bottoms","Footwear","Bags","Accessories","Outerwear","Activewear","Swimwear","Sleepwear","Ethnic","Kids"];
    k = 0;
    while k < len(all_cats) {
        c = all_cats[k];
        k = k + 1;
        cnt = cats[c];
        if cnt == null { cnt = 0; }
        result.append({"name": c, "count": cnt});
    }
    return json_ok(result);
}

def handle_recommendations_plp(req) {
    query    = req["query"];
    category = get_query_param(query, "category");
    gender   = get_query_param(query, "gender");
    limit    = parse_int_param(get_query_param(query, "limit"), 12);

    all_products = load_products_from_db();
    recs = rec_recommend_plp(all_products, category, gender, limit);
    return json_ok({"recommendations": recs, "count": len(recs)});
}

def handle_recommendations_pdp(req, product_id) {
    rows = db_query("SELECT * FROM products WHERE id = ?", [product_id]);
    if len(rows) == 0 {
        return json_err(404, "Product not found");
    }
    r = rows[0];
    target = {
        "id":       r["id"],
        "category": r["category"],
        "gender":   r["gender"],
        "brand":    r["brand"],
        "price":    r["price"]
    };
    limit = parse_int_param(get_query_param(req["query"], "limit"), 8);
    all_products = load_products_from_db();
    recs = rec_recommend_pdp(all_products, target, limit);
    return json_ok({"recommendations": recs, "count": len(recs)});
}

// ─── Cart Handlers ─────────────────────────────────────────────

def handle_get_cart(req, session_id) {
    if carts[session_id] == null {
        return json_ok({"items": [], "total": 0.0, "itemCount": 0});
    }
    items = carts[session_id];
    total = 0.0;
    count = 0;
    i = 0;
    while i < len(items) {
        total = total + items[i]["price"] * items[i]["quantity"];
        count = count + items[i]["quantity"];
        i = i + 1;
    }
    return json_ok({"items": items, "total": total, "itemCount": count});
}

def handle_add_to_cart(req, session_id) {
    body = from_json(req["body"]);
    product_id = body["productId"];
    size       = body["size"];
    color      = body["color"];
    quantity   = body["quantity"];
    if quantity == null { quantity = 1; }

    rows = db_query("SELECT * FROM products WHERE id = ?", [product_id]);
    if len(rows) == 0 {
        return json_err(404, "Product not found");
    }
    r = rows[0];

    if carts[session_id] == null {
        carts[session_id] = [];
    }
    items = carts[session_id];

    // Rebuild cart: update quantity if item exists, otherwise append
    new_items = [];
    found = false;
    i = 0;
    while i < len(items) {
        it = items[i];
        i = i + 1;
        if it["productId"] == product_id {
            if it["size"] == size {
                if it["color"] == color {
                    new_items.append({"productId": it["productId"], "name": it["name"], "price": it["price"], "size": it["size"], "color": it["color"], "quantity": it["quantity"] + quantity, "imageUrl": it["imageUrl"], "brand": it["brand"]});
                    found = true;
                } else {
                    new_items.append(it);
                }
            } else {
                new_items.append(it);
            }
        } else {
            new_items.append(it);
        }
    }

    if found == false {
        new_items.append({"productId": product_id, "name": r["name"], "price": r["price"], "size": size, "color": color, "quantity": quantity, "imageUrl": r["image_url"], "brand": r["brand"]});
    }
    carts[session_id] = new_items;

    // Kafka event
    kafka_produce("cart-events", session_id, to_json({"event": "ITEM_ADDED", "productId": product_id, "sessionId": session_id}));

    return handle_get_cart(req, session_id);
}

def handle_update_cart(req, session_id) {
    body = from_json(req["body"]);
    product_id = body["productId"];
    size       = body["size"];
    color      = body["color"];
    quantity   = body["quantity"];

    if carts[session_id] == null {
        return json_err(400, "Cart not found");
    }
    new_items = [];
    items = carts[session_id];
    i = 0;
    while i < len(items) {
        it = items[i];
        i = i + 1;
        is_match = false;
        if it["productId"] == product_id {
            if it["size"] == size {
                if it["color"] == color { is_match = true; }
            }
        }
        if is_match == true {
            if quantity > 0 {
                new_items.append({"productId": it["productId"], "name": it["name"], "price": it["price"], "size": it["size"], "color": it["color"], "quantity": quantity, "imageUrl": it["imageUrl"], "brand": it["brand"]});
            }
        } else {
            new_items.append(it);
        }
    }
    carts[session_id] = new_items;
    return handle_get_cart(req, session_id);
}

def handle_clear_cart(req, session_id) {
    carts[session_id] = [];
    return json_ok({"message": "Cart cleared"});
}

// ─── Checkout & Orders ────────────────────────────────────────

def handle_checkout(req, session_id) {
    body = from_json(req["body"]);
    address        = body["address"];
    payment_method = body["paymentMethod"];
    user_id        = body["userId"];
    if user_id == null { user_id = session_id; }

    if carts[session_id] == null {
        return json_err(400, "Cart is empty");
    }
    items = carts[session_id];
    if len(items) == 0 {
        return json_err(400, "Cart is empty");
    }

    // Calculate total
    total = 0.0;
    i = 0;
    while i < len(items) {
        total = total + items[i]["price"] * items[i]["quantity"];
        i = i + 1;
    }

    order_id = gen_order_id();
    now = "2026-04-15";

    // Save order
    db_exec("INSERT INTO orders (id, user_id, session_id, total, status, address, payment_method, estimated_delivery) VALUES (?, ?, ?, ?, 'CONFIRMED', ?, ?, '3-5 business days')",
            [order_id, user_id, session_id, total, to_json(address), payment_method]);

    // Save items
    j = 0;
    while j < len(items) {
        it = items[j];
        j = j + 1;
        db_exec("INSERT INTO order_items (order_id, product_id, name, price, quantity, size, color, image_url) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                [order_id, it["productId"], it["name"], it["price"], it["quantity"], it["size"], it["color"], it["imageUrl"]]);
        // Update stock
        db_exec("UPDATE products SET stock = stock - ? WHERE id = ?",
                [it["quantity"], it["productId"]]);
    }

    // Kafka events for downstream services
    kafka_produce("order-events", order_id, to_json({
        "event":   "ORDER_PLACED",
        "orderId": order_id,
        "userId":  user_id,
        "total":   total,
        "items":   len(items)
    }));
    kafka_produce("payment-events", order_id, to_json({
        "event":         "PAYMENT_REQUESTED",
        "orderId":       order_id,
        "amount":        total,
        "paymentMethod": payment_method
    }));

    // Clear cart
    carts[session_id] = [];

    // Cache order in Redis
    order_data = {
        "id":               order_id,
        "userId":           user_id,
        "items":            items,
        "total":            total,
        "status":           "CONFIRMED",
        "address":          address,
        "paymentMethod":    payment_method,
        "estimatedDelivery":"3-5 business days",
        "createdAt":        now
    };
    redis_setex("order:" + order_id, 3600, to_json(order_data));

    return json_ok(order_data);
}

def handle_get_order(req, order_id) {
    cached = redis_get("order:" + order_id);
    if cached != null {
        return {"status": 200, "body": cached, "content_type": "application/json"};
    }
    rows = db_query("SELECT * FROM orders WHERE id = ?", [order_id]);
    if len(rows) == 0 {
        return json_err(404, "Order not found");
    }
    o = rows[0];
    items = db_query("SELECT * FROM order_items WHERE order_id = ?", [order_id]);
    return json_ok({
        "id":               o["id"],
        "userId":           o["user_id"],
        "total":            o["total"],
        "status":           o["status"],
        "address":          from_json(o["address"]),
        "paymentMethod":    o["payment_method"],
        "estimatedDelivery":o["estimated_delivery"],
        "createdAt":        o["created_at"],
        "items":            items
    });
}

def handle_get_orders(req, session_id) {
    rows = db_query("SELECT * FROM orders WHERE session_id = ? ORDER BY created_at DESC", [session_id]);
    orders = [];
    i = 0;
    while i < len(rows) {
        o = rows[i];
        i = i + 1;
        items = db_query("SELECT * FROM order_items WHERE order_id = ?", [o["id"]]);
        orders.append({
            "id":            o["id"],
            "total":         o["total"],
            "status":        o["status"],
            "createdAt":     o["created_at"],
            "itemCount":     len(items)
        });
    }
    return json_ok(orders);
}

// ─── Review Handler ───────────────────────────────────────────

def handle_post_review(req, product_id) {
    body      = from_json(req["body"]);
    user_name = body["userName"];
    rating    = body["rating"];
    comment   = body["comment"];
    user_id   = body["userId"];
    if user_id == null { user_id = "guest"; }

    db_exec("INSERT INTO reviews (product_id, user_id, user_name, rating, comment) VALUES (?,?,?,?,?)",
            [product_id, user_id, user_name, rating, comment]);

    // Update product rating (rolling average)
    prod_rows = db_query("SELECT rating, review_count FROM products WHERE id = ?", [product_id]);
    if len(prod_rows) > 0 {
        old_rating = prod_rows[0]["rating"];
        old_count  = prod_rows[0]["review_count"];
        new_count  = old_count + 1;
        new_rating = (old_rating * old_count + rating) / new_count;
        db_exec("UPDATE products SET rating = ?, review_count = ? WHERE id = ?",
                [new_rating, new_count, product_id]);
        // Invalidate cache
        redis_del("product:" + product_id);
    }

    kafka_produce("review-events", product_id, to_json({
        "event":     "REVIEW_POSTED",
        "productId": product_id,
        "rating":    rating
    }));

    return json_ok({"message": "Review submitted successfully"});
}

// ─── User Auth (simple) ───────────────────────────────────────

def handle_register(req) {
    body  = from_json(req["body"]);
    email = body["email"];
    name  = body["name"];
    phone = body["phone"];

    existing = db_query("SELECT id FROM users WHERE email = ?", [email]);
    if len(existing) > 0 {
        return json_err(400, "Email already registered");
    }

    user_id = "USR-" + email;
    db_exec("INSERT INTO users (id, email, name, phone) VALUES (?,?,?,?)",
            [user_id, email, name, phone]);

    token = "tok-" + user_id;
    redis_setex("session:" + token, 86400, to_json({"userId": user_id, "email": email, "name": name}));

    return json_ok({"userId": user_id, "token": token, "name": name, "email": email});
}

def handle_login(req) {
    body  = from_json(req["body"]);
    email = body["email"];
    rows  = db_query("SELECT * FROM users WHERE email = ?", [email]);
    if len(rows) == 0 {
        return json_err(401, "Invalid credentials");
    }
    u = rows[0];
    token = "tok-" + u["id"];
    redis_setex("session:" + token, 86400, to_json({"userId": u["id"], "email": u["email"], "name": u["name"]}));
    return json_ok({"userId": u["id"], "token": token, "name": u["name"], "email": u["email"]});
}

// ─── Wishlist ─────────────────────────────────────────────────

def handle_wishlist_add(req) {
    body       = from_json(req["body"]);
    user_id    = body["userId"];
    product_id = body["productId"];
    if user_id == null { return json_err(401, "Login required"); }
    existing = db_query("SELECT id FROM wishlist WHERE user_id = ? AND product_id = ?", [user_id, product_id]);
    if len(existing) == 0 {
        db_exec("INSERT INTO wishlist (user_id, product_id) VALUES (?,?)", [user_id, product_id]);
    }
    return json_ok({"message": "Added to wishlist"});
}

def handle_wishlist_remove(req) {
    body       = from_json(req["body"]);
    user_id    = body["userId"];
    product_id = body["productId"];
    db_exec("DELETE FROM wishlist WHERE user_id = ? AND product_id = ?", [user_id, product_id]);
    return json_ok({"message": "Removed from wishlist"});
}

def handle_get_wishlist(req, user_id) {
    rows = db_query("SELECT p.* FROM wishlist w JOIN products p ON w.product_id = p.id WHERE w.user_id = ?", [user_id]);
    products = [];
    i = 0;
    while i < len(rows) {
        r = rows[i];
        i = i + 1;
        products.append({
            "id":       r["id"],
            "name":     r["name"],
            "brand":    r["brand"],
            "price":    r["price"],
            "imageUrl": r["image_url"],
            "rating":   r["rating"]
        });
    }
    return json_ok(products);
}

// ─── Search ───────────────────────────────────────────────────

def handle_search(req) {
    query = get_query_param(req["query"], "q");
    if query == "" {
        return json_ok({"products": [], "total": 0});
    }

    // Try cache
    cache_key = "search:" + lower(query);
    cached = redis_get(cache_key);
    if cached != null {
        return {"status": 200, "body": cached, "content_type": "application/json"};
    }

    all_products = load_products_from_db();
    results = [];
    q_lower = lower(query);
    i = 0;
    while i < len(all_products) {
        p = all_products[i];
        i = i + 1;
        is_match = false;
        if contains(lower(p["name"]), q_lower)     { is_match = true; }
        if contains(lower(p["brand"]), q_lower)    { is_match = true; }
        if contains(lower(p["category"]), q_lower) { is_match = true; }
        if is_match { results.append(p); }
    }

    resp = to_json({"products": results, "total": len(results), "query": query});
    redis_setex(cache_key, 120, resp);
    return {"status": 200, "body": resp, "content_type": "application/json"};
}

// ─── Trending & Featured ─────────────────────────────────────

def handle_trending(req) {
    limit = parse_int_param(get_query_param(req["query"], "limit"), 12);
    rows = db_query("SELECT * FROM products WHERE is_trending = 1 ORDER BY rating DESC LIMIT ?", [limit]);
    products = [];
    i = 0;
    while i < len(rows) {
        r = rows[i];
        i = i + 1;
        products.append({
            "id":       r["id"],
            "name":     r["name"],
            "brand":    r["brand"],
            "price":    r["price"],
            "originalPrice": r["original_price"],
            "discount": r["discount"],
            "imageUrl": r["image_url"],
            "rating":   r["rating"],
            "isTrending": true,
            "isNew":    r["is_new"] == 1
        });
    }
    return json_ok(products);
}

def handle_new_arrivals(req) {
    limit = parse_int_param(get_query_param(req["query"], "limit"), 12);
    rows = db_query("SELECT * FROM products WHERE is_new = 1 ORDER BY rating DESC LIMIT ?", [limit]);
    products = [];
    i = 0;
    while i < len(rows) {
        r = rows[i];
        i = i + 1;
        products.append({
            "id":       r["id"],
            "name":     r["name"],
            "brand":    r["brand"],
            "price":    r["price"],
            "originalPrice": r["original_price"],
            "discount": r["discount"],
            "imageUrl": r["image_url"],
            "rating":   r["rating"],
            "isNew":    true
        });
    }
    return json_ok(products);
}

// ─── Kafka Events Viewer ──────────────────────────────────────

def handle_events(req) {
    events = kafka_events();
    return json_ok({"events": events, "count": len(events)});
}

// ─── Router ──────────────────────────────────────────────────

def router(req) {
    method = req["method"];
    path   = req["path"];
    query  = req["query"];

    // CORS preflight
    if method == "OPTIONS" {
        return {"status": 204, "body": "", "content_type": "text/plain"};
    }

    // Static files
    if method == "GET" {
        if path == "/" {
            content = read_file("examples/ecommerce/frontend/public/index.html");
            return {"status": 200, "body": content, "content_type": "text/html"};
        }
        if ends_with(path, ".js") {
            js_path = "examples/ecommerce/frontend" + path;
            if file_exists(js_path) {
                content = read_file(js_path);
                return {"status": 200, "body": content, "content_type": "application/javascript"};
            }
        }
        if ends_with(path, ".css") {
            css_path = "examples/ecommerce/frontend" + path;
            if file_exists(css_path) {
                content = read_file(css_path);
                return {"status": 200, "body": content, "content_type": "text/css"};
            }
        }
    }

    // Extract path segments safely
    parts = split(path, "/");
    nparts = len(parts);

    p1 = "";
    p2 = "";
    p3 = "";
    p4 = "";
    if nparts >= 2 { p1 = parts[1]; }
    if nparts >= 3 { p2 = parts[2]; }
    if nparts >= 4 { p3 = parts[3]; }
    if nparts >= 5 { p4 = parts[4]; }

    // Session ID from header or query
    session_id = req["headers"]["x-session-id"];
    if session_id == null { session_id = get_query_param(query, "sessionId"); }
    if session_id == null { session_id = "guest-session"; }

    // API routes
    if p1 == "api" {
        // Health
        if p2 == "health" { return handle_health(req); }

        // Products
        if p2 == "products" {
            if p3 == "" {
                if method == "GET" { return handle_get_products(req); }
            } else {
                if p4 == "" {
                    if method == "GET" { return handle_get_product(req, p3); }
                }
                if p4 == "reviews" {
                    if method == "POST" { return handle_post_review(req, p3); }
                }
                if p4 == "recommendations" {
                    if method == "GET" { return handle_recommendations_pdp(req, p3); }
                }
            }
        }

        // Categories
        if p2 == "categories" {
            if method == "GET" { return handle_get_categories(req); }
        }

        // Search
        if p2 == "search" {
            if method == "GET" { return handle_search(req); }
        }

        // Trending
        if p2 == "trending" {
            if method == "GET" { return handle_trending(req); }
        }

        // New arrivals
        if p2 == "new-arrivals" {
            if method == "GET" { return handle_new_arrivals(req); }
        }

        // Recommendations (PLP)
        if p2 == "recommendations" {
            if method == "GET" { return handle_recommendations_plp(req); }
        }

        // Cart
        if p2 == "cart" {
            if p3 == "" {
                if method == "GET"    { return handle_get_cart(req, session_id); }
                if method == "POST"   { return handle_add_to_cart(req, session_id); }
                if method == "PUT"    { return handle_update_cart(req, session_id); }
                if method == "DELETE" { return handle_clear_cart(req, session_id); }
            }
        }

        // Checkout
        if p2 == "checkout" {
            if method == "POST" { return handle_checkout(req, session_id); }
        }

        // Orders
        if p2 == "orders" {
            if p3 == "" {
                if method == "GET" { return handle_get_orders(req, session_id); }
            } else {
                if method == "GET" { return handle_get_order(req, p3); }
            }
        }

        // Auth
        if p2 == "auth" {
            if p3 == "register" { if method == "POST" { return handle_register(req); } }
            if p3 == "login"    { if method == "POST" { return handle_login(req); } }
        }

        // Wishlist
        if p2 == "wishlist" {
            if p3 == "" {
                if method == "POST"   { return handle_wishlist_add(req); }
                if method == "DELETE" { return handle_wishlist_remove(req); }
            } else {
                if method == "GET" { return handle_get_wishlist(req, p3); }
            }
        }

        // Events (Kafka log)
        if p2 == "events" {
            if method == "GET" { return handle_events(req); }
        }

        return json_err(404, "API endpoint not found");
    }

    return json_err(404, "Not found");
}

// ─── Boot ─────────────────────────────────────────────────────

print("=== SHYNX Fashion E-Commerce — UniLang Backend ===");
print("Demonstrates: Java OOP + Python logic + SQLite + Redis + Kafka");
init_db();
seed_products();
redis_connect("redis://127.0.0.1:6379");
print("Redis connected");
print("Starting server on http://localhost:8080");
serve(8080, router);
