// ============================================================
//  SHYNX — Fashion E-Commerce Backend
//  UniLang demonstration: Java-style OOP + Python-style logic
//  SQLite (embedded) • Redis (cache) • Kafka (async events)
// ============================================================

// ─── Recommendation Engine ────────────────────────────────────
// Python-style ML scoring functions (feature weights as globals)

REC_W_RATING   = 0.35;
REC_W_TRENDING = 0.25;
REC_W_SALES    = 0.20;
REC_W_NEW      = 0.10;
REC_W_DISCOUNT = 0.10;

def rec_score_product(p) {
    rating_norm   = p["rating"] / 5.0;
    trending_flag = 0;
    if p["isTrending"] == true { trending_flag = 1; }
    new_flag = 0;
    if p["isNew"] == true { new_flag = 1; }
    discount_norm = p["discount"] / 100.0;
    sales_norm    = p["reviewCount"] / 1000.0;
    if sales_norm > 1.0 { sales_norm = 1.0; }
    score = (rating_norm * REC_W_RATING)
          + (trending_flag * REC_W_TRENDING)
          + (sales_norm * REC_W_SALES)
          + (new_flag * REC_W_NEW)
          + (discount_norm * REC_W_DISCOUNT);
    return score;
}

def rec_similarity(p, target) {
    score = 0.0;
    if p["category"] == target["category"] { score = score + 0.4; }
    if p["gender"] == target["gender"]     { score = score + 0.2; }
    if p["brand"] == target["brand"]       { score = score + 0.2; }
    diff = p["price"] - target["price"];
    if diff < 0 { diff = diff * -1; }
    price_ratio = diff / target["price"];
    if price_ratio < 0.3 { score = score + 0.2; }
    return score;
}

def rec_sort_by_score(scored) {
    n = len(scored);
    i = 0;
    while i < n {
        j = 0;
        while j < n - i - 1 {
            if scored[j]["score"] < scored[j+1]["score"] {
                tmp = scored[j];
                scored[j] = scored[j+1];
                scored[j+1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return scored;
}

// PLP recommendations: filter + score for listing pages
def rec_recommend_plp(products, category, gender, limit) {
    scored = [];
    i = 0;
    while i < len(products) {
        p = products[i];
        i = i + 1;
        cat_match = 0;
        gen_match = 0;
        if p["category"] == category { cat_match = 1; }
        if category == "" { cat_match = 1; }
        if p["gender"] == gender { gen_match = 1; }
        if gender == "all" { gen_match = 1; }
        if gender == "" { gen_match = 1; }
        if cat_match == 0 { continue; }
        if gen_match == 0 { continue; }
        score = rec_score_product(p);
        scored.append({"product": p, "score": score});
    }
    scored = rec_sort_by_score(scored);
    result = [];
    j = 0;
    while j < len(scored) {
        if j >= limit { break; }
        result.append(scored[j]["product"]);
        j = j + 1;
    }
    return result;
}

// PDP recommendations: similar products
def rec_recommend_pdp(products, target_product, limit) {
    scored = [];
    i = 0;
    while i < len(products) {
        p = products[i];
        i = i + 1;
        if p["id"] == target_product["id"] { continue; }
        sim = rec_similarity(p, target_product);
        if sim > 0.0 {
            scored.append({"product": p, "score": sim});
        }
    }
    scored = rec_sort_by_score(scored);
    result = [];
    j = 0;
    while j < len(scored) {
        if j >= limit { break; }
        result.append(scored[j]["product"]);
        j = j + 1;
    }
    return result;
}

// ─── Global State ─────────────────────────────────────────────

// In-memory carts: { sessionId -> [CartItem dict, ...] }
carts = {};

// In-memory sessions: { sessionId -> userInfo dict }
sessions = {};

// Global order counter
order_counter = 1000;

// ─── Database Initialization ──────────────────────────────────

def init_db() {
    db_connect("sqlite://ecommerce.db");

    // Users table
    db_exec("CREATE TABLE IF NOT EXISTS users (id TEXT PRIMARY KEY, email TEXT UNIQUE NOT NULL, name TEXT NOT NULL, phone TEXT, password_hash TEXT, created_at TEXT DEFAULT CURRENT_TIMESTAMP)", []);

    // Products table (master catalog)
    db_exec("CREATE TABLE IF NOT EXISTS products (id TEXT PRIMARY KEY, name TEXT NOT NULL, brand TEXT, category TEXT, subcategory TEXT, price REAL, original_price REAL, discount INTEGER, image_url TEXT, description TEXT, stock INTEGER DEFAULT 0, rating REAL DEFAULT 0, review_count INTEGER DEFAULT 0, is_trending INTEGER DEFAULT 0, is_new INTEGER DEFAULT 0, gender TEXT, sizes TEXT, colors TEXT, tags TEXT)", []);

    // Orders table
    db_exec("CREATE TABLE IF NOT EXISTS orders (id TEXT PRIMARY KEY, user_id TEXT, session_id TEXT, total REAL, status TEXT DEFAULT 'CONFIRMED', address TEXT, payment_method TEXT, estimated_delivery TEXT, created_at TEXT DEFAULT CURRENT_TIMESTAMP)", []);

    // Order items table
    db_exec("CREATE TABLE IF NOT EXISTS order_items (id INTEGER PRIMARY KEY AUTOINCREMENT, order_id TEXT, product_id TEXT, name TEXT, price REAL, quantity INTEGER, size TEXT, color TEXT, image_url TEXT)", []);

    // Reviews table
    db_exec("CREATE TABLE IF NOT EXISTS reviews (id INTEGER PRIMARY KEY AUTOINCREMENT, product_id TEXT, user_id TEXT, user_name TEXT, rating REAL, comment TEXT, created_at TEXT DEFAULT CURRENT_TIMESTAMP)", []);

    // Wishlist
    db_exec("CREATE TABLE IF NOT EXISTS wishlist (id INTEGER PRIMARY KEY AUTOINCREMENT, user_id TEXT, product_id TEXT, created_at TEXT DEFAULT CURRENT_TIMESTAMP)", []);

    print("Database initialized");
}

